# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model Configuration (per Technical Architecture)
# Agents 2-8 use a smaller model for cost efficiency
# Agent 10 (Synthesis) uses the most capable model
MODEL_AGENTS_1_9=claude-sonnet-4-6
MODEL_AGENT_10=claude-opus-4-6

# Database
DATABASE_URL=sqlite:///data/sis.db

