# Riskified LLM Proxy Configuration (requires VPN)
ANTHROPIC_API_KEY=sk-your-proxy-key-here
ANTHROPIC_BASE_URL=https://llm-proxy.main2.management.riskxint.com

# Model Configuration (proxy uses anthropic/ prefix)
MODEL_AGENTS_1_8=anthropic/claude-sonnet-4-20250514
MODEL_AGENTS_9_10=anthropic/claude-opus-4-20250514

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///data/sis.db
# DATABASE_URL=postgresql://postgres:sis@localhost:5432/sis

